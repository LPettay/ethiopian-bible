:80 {
	root * /srv

	# Compression
	encode zstd gzip

	# Cache static assets aggressively (JS, CSS, images, fonts)
	@static path *.js *.css *.svg *.png *.jpg *.jpeg *.webp *.woff *.woff2 *.ico
	header @static Cache-Control "public, max-age=31536000, immutable"

	# Cache JSON data files (shorter TTL — content may update)
	@data path /data/*
	header @data Cache-Control "public, max-age=3600"

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-XSS-Protection "1; mode=block"
		-Server
	}

	# SPA fallback: serve index.html for any path that doesn't match a file
	try_files {path} /index.html
	file_server
}
